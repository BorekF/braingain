# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase — https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI — https://platform.openai.com/api-keys (used for quiz generation)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Groq (optional) — https://console.groq.com/keys (audio transcription fallback)
GROQ_API_KEY=gsk_your-groq-api-key-here

# Admin panel password (use a long random string)
ADMIN_SECRET=your-very-secure-admin-password-change-this

# Demo rate limiting (optional, max quiz generations per IP per 24h)
DEMO_RATE_LIMIT_MAX=5

NODE_ENV=development
